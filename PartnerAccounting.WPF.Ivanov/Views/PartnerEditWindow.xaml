<Window x:Class="PartnerAccounting.WPF.Ivanov.Views.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PartnerAccounting.WPF.Ivanov.Views"
        mc:Ignorable="d"
    Title="Редактирование партнера" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" 
                   Text="Добавление партнера"
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   Foreground="#2C3E50"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Тип партнера *" Margin="0,0,0,5"/>
                <ComboBox x:Name="TypeBox" 
                          Margin="0,0,0,15" 
                          Padding="8"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>

                <TextBlock Text="Наименование компании *" Margin="0,0,0,5"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,15" Padding="8"/>

                <TextBlock Text="Юридический адрес *" Margin="0,0,0,5"/>
                <TextBox x:Name="AddressBox" Margin="0,0,0,15" Padding="8"/>

                <TextBlock Text="ИНН *" Margin="0,0,0,5"/>
                <TextBox x:Name="InnBox" Margin="0,0,0,15" Padding="8" MaxLength="12"/>

                <TextBlock Text="ФИО директора *" Margin="0,0,0,5"/>
                <TextBox x:Name="DirectorBox" Margin="0,0,0,15" Padding="8"/>

                <TextBlock Text="Телефон *" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneBox" Margin="0,0,0,15" Padding="8"/>

                <TextBlock Text="Email *" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailBox" Margin="0,0,0,15" Padding="8"/>

                <TextBlock Text="Рейтинг *" Margin="0,0,0,5"/>
                <TextBox x:Name="RatingBox" Margin="0,0,0,15" Padding="8" MaxLength="5"/>

                <TextBlock Text="* обязательные поля" 
                           Foreground="Gray" 
                           FontStyle="Italic"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="Save_Click"
                    Background="#27AE60"
                    Foreground="White"
                    Padding="20,8"
                    Margin="0,0,10,0"
                    FontWeight="Bold"/>

            <Button Content="Отмена" 
                    Click="Cancel_Click"
                    Background="#E74C3C"
                    Foreground="White"
                    Padding="20,8"
                    FontWeight="Bold"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>