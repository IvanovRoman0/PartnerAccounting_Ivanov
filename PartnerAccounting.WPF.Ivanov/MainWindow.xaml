<Window x:Class="PartnerAccounting.WPF.Ivanov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:local="clr-namespace:PartnerAccounting.WPF.Ivanov"
   Title="Мастер пол - Учет партнеров" 
        Height="700" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Segoe UI"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Рабочее меню -->
        <Menu Grid.Row="0" Background="White" Height="30" Margin="10,5,0,0">
            <MenuItem Header="_Офис">
                <MenuItem Header="Главная" Click="OfficeHome_Click"/>
                <Separator/>
                <MenuItem Header="Выход" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Партнеры">
                <MenuItem Header="Добавить партнера" Click="AddPartner_Click"/>
                <Separator/>
                <MenuItem Header="Все партнеры" Click="ShowAllPartners_Click"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="О программе" Click="AboutMenuItem_Click"/>
                <MenuItem Header="Помощь" Click="Help_Click"/>
            </MenuItem>
        </Menu>

        <!-- Разделительная линия после меню -->
        <Border Grid.Row="1" Height="1" Background="#E0E0E0" Margin="0"/>

        <!-- Заголовок "Список партнеров" -->
        <TextBlock Grid.Row="2" 
                   Text="Список партнеров" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="20,15,0,15"
                   Foreground="#2C3E50"/>

        <!-- Основная область с двумя колонками -->
        <Grid Grid.Row="3" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="30"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка - Список партнеров -->
            <ScrollViewer Grid.Column="0" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,20,0">
                <ItemsControl x:Name="PartnersItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Карточка партнера -->
                            <Border Background="White" 
                                    BorderBrush="#E0E0E0" 
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,0,15"
                                    Padding="15"
                                    Tag="{Binding Id}"
                                    MouseLeftButtonUp="PartnerCard_MouseLeftButtonUp"
                                    Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Информация о партнере -->
                                    <StackPanel Grid.Column="0">
                                        <!-- Тип и наименование жирным -->
                                        <TextBlock FontWeight="Bold" FontSize="16">
                                            <Run Text="{Binding PartnerType.Name}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding Name}"/>
                                        </TextBlock>

                                        <!-- Директор -->
                                        <TextBlock Text="{Binding DirectorName}" 
                                                   Margin="0,8,0,5"
                                                   FontSize="14"/>

                                        <!-- Телефон -->
                                        <TextBlock Text="{Binding Phone}" 
                                                   FontSize="14"/>

                                        <!-- Рейтинг -->
                                        <TextBlock Margin="0,8,0,0" FontSize="14">
                                            <Run Text="Рейтинг: " FontWeight="Normal"/>
                                            <Run Text="{Binding Rating}" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Скидка крупным шрифтом справа -->
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DiscountDisplay}" 
                                               FontSize="24" 
                                               FontWeight="Bold"
                                               Foreground="#E67E22"
                                               VerticalAlignment="Center"
                                               Margin="20,0,10,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" 
                          Width="3" 
                          HorizontalAlignment="Center"
                          Background="#E0E0E0"
                          Margin="0"/>

            <!-- Правая колонка - Список заказов выбранного партнера -->
            <Border Grid.Column="2" 
                    Background="White" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="20"
                    Margin="20,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Grid.Row="0" 
                               Text="Список заказов выбранного партнера" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="0,0,0,15"/>

                    <!-- Информация о выбранном партнере -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock x:Name="SelectedPartnerTitle" 
                                   Text=""
                                   FontWeight="Bold" 
                                   FontSize="16"/>
                        <TextBlock x:Name="SelectedPartnerDetails" 
                                   Text="" 
                                   Foreground="#666666"
                                   FontSize="14"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Таблица заказов -->
                    <ListView x:Name="OrdersListView" 
                              Grid.Row="2"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              MinHeight="200">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Дата" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SaleDate, StringFormat={}{0:dd.MM.yyyy}}" Margin="5"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Товар" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Product.Name}" Margin="5" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Кол-во" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Quantity}" Margin="5"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Сумма" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N2} ₽}" Margin="5"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Маленькие кнопки под таблицей -->
                    <StackPanel Grid.Row="4" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                Margin="0,15,0,0">
                        <Button Content="Редактировать" 
                                x:Name="EditButton"
                                Click="EditPartner_Click"
                                Background="#3498DB"
                                Foreground="White"
                                BorderThickness="0"
                                Width="100" Height="30"
                                FontSize="14"
                                Margin="0,0,5,0"
                                Padding="0"
                                ToolTip="Редактировать партнера"
                                Cursor="Hand"
                                Visibility="Collapsed"/>

                        <Button Content="Удалить" 
                                x:Name="DeleteButton"
                                Click="DeletePartner_Click"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderThickness="0"
                                Width="90" Height="30"
                                FontSize="14"
                                Padding="0"
                                ToolTip="Удалить партнера"
                                Cursor="Hand"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>